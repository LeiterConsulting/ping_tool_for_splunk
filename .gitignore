# Logs (keep structure, ignore content)
logs/*.log
logs/*_*.log

# Keep the logs directory
!logs/.gitkeep

# PowerShell module cache
*.psm1.cache

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Sensitive files (tokens, credentials)
*.secret
*.credentials

# NSSM executable (downloaded at runtime)
nssm.exe

# Discovery output (generated)
discovered_endpoints.csv

# Internal development documentation (not shipped)
documentation/

# Test suite and artifacts (not shipped)
tests/

# Future feature ideas
future_features/
