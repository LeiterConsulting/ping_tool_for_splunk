<dashboard version="1.1" theme="dark">
  <label>Ping Monitor Setup</label>
  <description>Configure global settings for the Ping Monitor application</description>
  
  <!-- Initialize defaults - but NOT the form tokens that trigger save -->
  <init>
    <set token="default_index">ping</set>
    <set token="default_sourcetype">ping_monitor</set>
    <set token="default_metrics_index">ping_metrics</set>
  </init>

  <!-- Load existing configuration into display tokens (not form tokens) -->
  <search id="load_existing_config">
    <query>| inputlookup ping_monitor_settings_lookup 
| search _key="global" 
| head 1
| append [| makeresults | eval index="ping", sourcetype="ping_monitor", metrics_index="ping_metrics", configured="false", last_updated="Never"]
| head 1
| eval index=coalesce(index, "ping"), sourcetype=coalesce(sourcetype, "ping_monitor"), metrics_index=coalesce(metrics_index, "ping_metrics")
| eval is_configured=if(configured=="true", "yes", "no")</query>
    <earliest>-1m</earliest>
    <latest>now</latest>
    <done>
      <condition match="'result.is_configured'==&quot;yes&quot;">
        <set token="current_index">$result.index$</set>
        <set token="current_sourcetype">$result.sourcetype$</set>
        <set token="current_metrics_index">$result.metrics_index$</set>
        <set token="current_last_updated">$result.last_updated$</set>
        <set token="is_configured">true</set>
        <set token="form.form_index">$result.index$</set>
        <set token="form.form_sourcetype">$result.sourcetype$</set>
        <set token="form.form_metrics_index">$result.metrics_index$</set>
      </condition>
      <condition>
        <set token="current_index">ping</set>
        <set token="current_sourcetype">ping_monitor</set>
        <set token="current_metrics_index">ping_metrics</set>
        <set token="current_last_updated">Never</set>
        <unset token="is_configured"/>
        <set token="form.form_index">ping</set>
        <set token="form.form_sourcetype">ping_monitor</set>
        <set token="form.form_metrics_index">ping_metrics</set>
      </condition>
    </done>
  </search>

  <!-- ==================== SECTION 1: Header & Overview ==================== -->
  <row>
    <panel>
      <html>
        <style>
          .setup-hero {
            background: linear-gradient(135deg, #1a2a3a 0%, #0d1520 100%);
            padding: 30px;
            border-radius: 10px;
            border: 1px solid #2a4a6a;
            text-align: center;
            margin-bottom: 10px;
          }
          .setup-hero h1 { color: #5cc05c; font-size: 32px; margin: 0 0 10px 0; }
          .setup-hero p { color: #99aabc; font-size: 16px; margin: 0; }
          .section-header {
            background: #1a1a2e;
            padding: 15px 20px;
            border-radius: 8px 8px 0 0;
            border-bottom: 2px solid #5cc05c;
            margin-bottom: -1px;
          }
          .section-header h2 { color: #5cc05c; margin: 0; font-size: 18px; }
          .section-header p { color: #888; margin: 5px 0 0 0; font-size: 13px; }
          .info-box {
            padding: 15px;
            background: #1a2a3a;
            border-radius: 5px;
            border-left: 4px solid #6db7c6;
          }
          .info-box.success { border-left-color: #5cc05c; }
          .info-box.warning { border-left-color: #f8be34; }
        </style>
        <div class="setup-hero">
          <h1>🎯 Ping Monitor Setup</h1>
          <p>Configure your Splunk index settings below. These settings are used by all dashboards and saved searches.</p>
        </div>
      </html>
    </panel>
  </row>

  <!-- ==================== SECTION 2: Current Configuration Status ==================== -->
  <row>
    <panel>
      <html>
        <div class="section-header">
          <h2>📋 Step 1: Review Current Configuration</h2>
          <p>Check if your settings have been saved. If not configured, default values will be used.</p>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <title>Current Saved Settings (from KV Store)</title>
      <table>
        <search>
          <query>| inputlookup ping_monitor_settings_lookup 
| search _key="global" 
| head 1
| append [| makeresults | eval index="ping", sourcetype="ping_monitor", metrics_index="ping_metrics", configured="false", last_updated="Never"]
| head 1
| eval status=if(configured=="true", "✅ Configured", "⚠️ Using Defaults")
| eval last_updated_display=coalesce(last_updated, "Never")
| table status, index, sourcetype, metrics_index, last_updated_display
| rename status as "Status", index as "Events Index", sourcetype as "Sourcetype", metrics_index as "Metrics Index", last_updated_display as "Last Updated"</query>
          <earliest>-1m</earliest>
          <latest>now</latest>
          <refresh>5s</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="drilldown">none</option>
        <option name="count">1</option>
      </table>
    </panel>
  </row>

  <!-- ==================== SECTION 3: Configuration Form ==================== -->
  <row>
    <panel>
      <html>
        <div class="section-header">
          <h2>⚙️ Step 2: Configure Index Settings</h2>
          <p>Enter your Splunk index and sourcetype values, then click <strong>Save Configuration</strong> to save.</p>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <html>
        <div class="info-box">
          <p style="color: #6db7c6; margin: 0;">
            <strong>💡 Instructions:</strong> Enter your settings below and click "Save Configuration". 
            The settings will be stored in the KV Store and used by all Ping Monitor dashboards.
          </p>
        </div>
      </html>
    </panel>
  </row>

  <!-- Form inputs - Submit button triggers the save -->
  <fieldset submitButton="false" autoRun="false">
    <input type="text" token="form_index" searchWhenChanged="false">
      <label>Events Index</label>
      <default>ping</default>
    </input>
    <input type="text" token="form_sourcetype" searchWhenChanged="false">
      <label>Sourcetype</label>
      <default>ping_monitor</default>
    </input>
    <input type="text" token="form_metrics_index" searchWhenChanged="false">
      <label>Metrics Index</label>
      <default>ping_metrics</default>
    </input>
    <input type="link" token="trigger_save">
      <label></label>
      <choice value="save">💾 Save Configuration</choice>
      <change>
        <condition value="save">
          <set token="do_save">true</set>
          <set token="save_time">$time$</set>
        </condition>
      </change>
    </input>
    <input type="link" token="trigger_reset">
      <label></label>
      <choice value="reset">🔄 Hide Save Result</choice>
      <change>
        <condition value="reset">
          <unset token="do_save"/>
        </condition>
      </change>
    </input>
  </fieldset>

  <!-- Save Configuration - Only runs when do_save token is set by clicking Save button -->
  <row depends="$do_save$">
    <panel>
      <title>💾 Save Result</title>
      <table>
        <search>
          <query>| makeresults 
| eval _key="global", 
       index="$form_index$", 
       sourcetype="$form_sourcetype$", 
       metrics_index="$form_metrics_index$",
       configured="true",
       last_updated=strftime(now(), "%Y-%m-%d %H:%M:%S")
| table _key, index, sourcetype, metrics_index, configured, last_updated
| outputlookup ping_monitor_settings_lookup key_field=_key
| eval result="✅ Configuration saved successfully at " . last_updated
| eval details="Events Index: " . index . " | Sourcetype: " . sourcetype . " | Metrics Index: " . metrics_index
| table result, details
| rename result as "Status", details as "Saved Settings"</query>
          <earliest>-1m</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">1</option>
      </table>
    </panel>
  </row>

  <!-- Refresh instructions -->
  <row>
    <panel>
      <html>
        <div class="info-box warning" style="border-left-color: #f8be34;">
          <p style="color: #f8be34; margin: 0;">
            <strong>⚠️ After Saving:</strong> Refresh this page to see the updated "Current Saved Settings" above.
            Other dashboards will automatically use the new settings on their next page load.
          </p>
        </div>
      </html>
    </panel>
  </row>

  <!-- ==================== SECTION 3: Next Steps ==================== -->
  <row>
    <panel>
      <html>
        <div class="section-header">
          <h2>✅ Step 3: Setup Complete - Next Steps</h2>
          <p>Your Ping Monitor is configured. Visit the Overview dashboard to verify your data is displaying correctly.</p>
        </div>
      </html>
    </panel>
  </row>

  <row>
    <panel>
      <html>
        <div style="padding: 25px; background: linear-gradient(135deg, #1a2a3a 0%, #0d1520 100%); border-radius: 8px; border: 1px solid #2a4a6a;">
          <table style="width: 100%; border-collapse: separate; border-spacing: 0 15px;">
            <tr>
              <td style="width: 60px; vertical-align: top;">
                <span style="font-size: 28px;">📊</span>
              </td>
              <td>
                <strong style="color: #5cc05c; font-size: 16px;">View Your Dashboard</strong>
                <p style="color: #aaa; margin: 5px 0 0 0;">Go to <strong>Ping Monitor Overview</strong> to see availability, latency, and health status for all monitored endpoints. Choose between Events, Metrics, or Combined view.</p>
              </td>
            </tr>
            <tr>
              <td style="width: 60px; vertical-align: top;">
                <span style="font-size: 28px;">🔍</span>
              </td>
              <td>
                <strong style="color: #6db7c6; font-size: 16px;">Discover Related Assets</strong>
                <p style="color: #aaa; margin: 5px 0 0 0;">Use <strong>Asset Discovery</strong> to find other Splunk indexes that contain data about your monitored IP addresses and hostnames.</p>
              </td>
            </tr>
            <tr>
              <td style="width: 60px; vertical-align: top;">
                <span style="font-size: 28px;">🔗</span>
              </td>
              <td>
                <strong style="color: #f8be34; font-size: 16px;">Correlate Health Data</strong>
                <p style="color: #aaa; margin: 5px 0 0 0;">Visit <strong>Asset Health Correlation</strong> to analyze service impact and correlate ping health with other data sources using the lookup table.</p>
              </td>
            </tr>
            <tr>
              <td style="width: 60px; vertical-align: top;">
                <span style="font-size: 28px;">⏰</span>
              </td>
              <td>
                <strong style="color: #dc4e41; font-size: 16px;">Enable Scheduled Searches</strong>
                <p style="color: #aaa; margin: 5px 0 0 0;">Go to <strong>Settings - Saved Searches</strong> to enable alerts for endpoint down, high packet loss, and high latency conditions.</p>
              </td>
            </tr>
          </table>
        </div>
      </html>
    </panel>
  </row>

</dashboard>
