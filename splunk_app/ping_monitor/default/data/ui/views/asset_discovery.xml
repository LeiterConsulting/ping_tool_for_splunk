<dashboard version="1.1" theme="dark">
  <label>Asset Discovery</label>
  <description>Discover Splunk indexes and sourcetypes that contain data matching your monitored endpoints</description>
  
  <!-- Load configuration from KV Store -->
  <search id="load_config">
    <query>| inputlookup ping_monitor_settings_lookup 
| search _key="global" 
| head 1
| eval index=coalesce(index, "ping"), sourcetype=coalesce(sourcetype, "ping_monitor"), metrics_index=coalesce(metrics_index, "ping_metrics")</query>
    <earliest>-1m</earliest>
    <latest>now</latest>
    <done>
      <set token="pm_index">$result.index$</set>
      <set token="pm_sourcetype">$result.sourcetype$</set>
      <set token="pm_metrics_index">$result.metrics_index$</set>
    </done>
  </search>
  
  <init>
    <set token="pm_index">ping</set>
    <set token="pm_sourcetype">ping_monitor</set>
    <set token="pm_metrics_index">ping_metrics</set>
    <set token="show_events">true</set>
  </init>
  
  <fieldset submitButton="false" autoRun="true">
    <input type="dropdown" token="data_source" searchWhenChanged="true">
      <label>Data Source</label>
      <choice value="events">Events</choice>
      <choice value="metrics">Metrics</choice>
      <choice value="combined">Combined</choice>
      <default>events</default>
      <change>
        <condition value="events">
          <set token="show_events">true</set>
          <unset token="show_metrics"></unset>
          <unset token="show_combined"></unset>
        </condition>
        <condition value="metrics">
          <unset token="show_events"></unset>
          <set token="show_metrics">true</set>
          <unset token="show_combined"></unset>
        </condition>
        <condition value="combined">
          <set token="show_events">true</set>
          <set token="show_metrics">true</set>
          <set token="show_combined">true</set>
        </condition>
      </change>
    </input>
    <input type="time" token="time_range" searchWhenChanged="true">
      <label>Discovery Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <!-- Data Source Indicator -->
  <row>
    <panel>
      <html>
        <div style="padding: 10px; background: #1a1a2e; border-radius: 5px; text-align: center;">
          <span style="color: #6db7c6; font-weight: bold;">📊 Data Source:</span>
          <span style="color: #fff; margin-left: 10px;">$data_source|s$</span>
          <span style="color: #888; margin-left: 20px;">
            Events Index: <strong>$pm_index$</strong> | 
            Metrics Index: <strong>$pm_metrics_index$</strong>
          </span>
        </div>
      </html>
    </panel>
  </row>

  <!-- Row 1: Summary Statistics - EVENTS -->
  <row depends="$show_events$">
    <panel>
      <single>
        <title>Total Monitored Assets (Events)</title>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(hostname) as asset_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x53a051","0x53a051"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Unique IP Addresses (Events)</title>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(target_ip) as ip_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x65a637","0x65a637"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Unique Groups (Events)</title>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(group) as group_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x6db7c6","0x6db7c6"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Entity Types (Events)</title>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(entitytype) as type_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0xf8be34","0xf8be34"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
  </row>

  <!-- Row 1: Summary Statistics - METRICS -->
  <row depends="$show_metrics$" rejects="$show_combined$">
    <panel>
      <single>
        <title>Total Monitored Assets (Metrics)</title>
        <search>
          <query>| mstats count("ping.pings_sent") as count WHERE index="$pm_metrics_index$" BY hostname
| stats dc(hostname) as asset_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x6db7c6","0x6db7c6"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Unique IP Addresses (Metrics)</title>
        <search>
          <query>| mstats count("ping.pings_sent") as count WHERE index="$pm_metrics_index$" BY target_ip
| stats dc(target_ip) as ip_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x6db7c6","0x6db7c6"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Unique Groups (Metrics)</title>
        <search>
          <query>| mstats count("ping.pings_sent") as count WHERE index="$pm_metrics_index$" BY group
| stats dc(group) as group_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x6db7c6","0x6db7c6"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    <panel>
      <single>
        <title>Metric Data Points</title>
        <search>
          <query>| mstats count("ping.pings_sent") as count WHERE index="$pm_metrics_index$"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">none</option>
        <option name="rangeColors">["0x6db7c6","0x6db7c6"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>
  </row>

  <!-- Row 2: Asset Inventory - EVENTS -->
  <row depends="$show_events$">
    <panel>
      <title>Monitored Assets from Ping Data (Events)</title>
      <table>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats latest(target_ip) as ip_address,
        latest(group) as group,
        latest(entitytype) as entity_type,
        latest(device) as device,
        latest(vendor) as vendor,
        latest(description) as description
        by hostname
| table hostname, ip_address, group, entity_type, device, vendor, description
| sort hostname</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">20</option>
      </table>
    </panel>
  </row>

  <!-- Row 2: Asset Inventory - METRICS -->
  <row depends="$show_metrics$" rejects="$show_combined$">
    <panel>
      <title>Monitored Assets from Ping Data (Metrics)</title>
      <table>
        <search>
          <query>| mstats count("ping.pings_sent") as pings WHERE index="$pm_metrics_index$" BY hostname, target_ip, group
| stats first(target_ip) as ip_address, first(group) as group, sum(pings) as total_pings by hostname
| table hostname, ip_address, group, total_pings
| sort hostname</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">20</option>
      </table>
    </panel>
  </row>

  <!-- Row 3: Your Monitored IPs - Simple List -->
  <row depends="$show_events$">
    <panel>
      <title>Your Monitored IP Addresses</title>
      <html>
        <div style="padding: 10px; background: #1a2a3a; border-radius: 5px; margin-bottom: 10px;">
          <p style="color: #6db7c6; margin: 0;">
            <strong>💡 Tip:</strong> Use the "Quick Asset Search" below to find which indexes contain data about a specific IP or hostname.
            Copy an IP address from the table below and paste it into the search field.
          </p>
        </div>
      </html>
      <table>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats count as ping_records, latest(hostname) as hostname, latest(group) as group by target_ip
| sort -ping_records
| head 50
| table target_ip, hostname, group, ping_records
| rename target_ip as "IP Address", hostname as "Hostname", group as "Group", ping_records as "Ping Records"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">15</option>
      </table>
    </panel>
    <panel>
      <title>Your Monitored Hostnames</title>
      <html>
        <div style="padding: 10px; background: #1a2a3a; border-radius: 5px; margin-bottom: 10px;">
          <p style="color: #6db7c6; margin: 0;">
            <strong>💡 Tip:</strong> These hostnames can be used with the lookup table to enrich other Splunk data.
            Use <code>| lookup ping_health_lookup.csv hostname</code> in your searches.
          </p>
        </div>
      </html>
      <table>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats count as ping_records, latest(target_ip) as ip_address, latest(group) as group by hostname
| sort -ping_records
| head 50
| table hostname, ip_address, group, ping_records
| rename hostname as "Hostname", ip_address as "IP Address", group as "Group", ping_records as "Ping Records"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">15</option>
      </table>
    </panel>
  </row>

  <!-- Row 4: Quick Discovery Search -->
  <row>
    <panel>
      <html>
        <div style="padding: 15px; background: linear-gradient(135deg, #1a2a3a 0%, #0d1520 100%); border-radius: 8px; border: 1px solid #2a4a6a;">
          <h3 style="color: #5cc05c; margin: 0 0 10px 0;">🔍 Quick Asset Search</h3>
          <p style="color: #aaa; margin: 0;">
            Enter an IP address or hostname to search across ALL your Splunk indexes. 
            This helps you discover where your monitored assets appear in other data sources (firewalls, servers, applications, etc.)
          </p>
        </div>
      </html>
    </panel>
  </row>
  
  <row>
    <panel>
      <input type="text" token="search_asset_input" searchWhenChanged="false">
        <label>IP or Hostname (press Enter to search)</label>
        <default></default>
        <change>
          <condition match="len('$value$') > 2">
            <set token="search_asset">$value$</set>
          </condition>
          <condition>
            <unset token="search_asset"/>
          </condition>
        </change>
      </input>
    </panel>
  </row>
  
  <row depends="$search_asset$">
    <panel>
      <title>Indexes Containing: $search_asset$</title>
      <html>
        <div style="padding: 10px; background: #2a2a2a; border-radius: 5px; margin-bottom: 10px;">
          <p style="color: #f8be34; margin: 0;">
            <strong>⚠️ Note:</strong> This search scans all indexes. Results will appear as matching data is found.
            Large environments may take longer to complete.
          </p>
        </div>
      </html>
      <table>
        <search>
          <query>search index=* (host="$search_asset$" OR host="*$search_asset$*" OR src_ip="$search_asset$" OR dest_ip="$search_asset$" OR src="$search_asset$" OR dest="$search_asset$" OR "$search_asset$")
| stats count by index, sourcetype, host
| sort -count
| head 50
| rename count as "Events", host as "Host"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="count">20</option>
      </table>
    </panel>
  </row>

  <!-- Row 5: Assets by Group - EVENTS -->
  <row depends="$show_events$">
    <panel>
      <title>Assets by Group (Events)</title>
      <chart>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(hostname) as host_count by group
| sort -host_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <title>Assets by Entity Type (Events)</title>
      <chart>
        <search>
          <query>index=$pm_index$ sourcetype=$pm_sourcetype$ record_type=summary
| stats dc(hostname) as host_count by entitytype
| sort -host_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

  <!-- Row 5: Assets by Group - METRICS -->
  <row depends="$show_metrics$" rejects="$show_combined$">
    <panel>
      <title>Assets by Group (Metrics)</title>
      <chart>
        <search>
          <query>| mstats count("ping.pings_sent") as count WHERE index="$pm_metrics_index$" BY hostname, group
| stats dc(hostname) as host_count by group
| sort -host_count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
    <panel>
      <title>Data Points by Group (Metrics)</title>
      <chart>
        <search>
          <query>| mstats count("ping.pings_sent") as data_points WHERE index="$pm_metrics_index$" BY group
| sort -data_points</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>

  <!-- Row 6: Usage Instructions -->
  <row>
    <panel>
      <html>
        <div style="padding: 20px; background: linear-gradient(135deg, #1a2a3a 0%, #0d1520 100%); border-radius: 8px; border: 1px solid #2a4a6a;">
          <h3 style="color: #5cc05c; margin: 0 0 15px 0;">📖 How to Use Asset Discovery</h3>
          <table style="width: 100%;">
            <tr>
              <td style="width: 40px; vertical-align: top; color: #5cc05c; font-size: 18px;">1.</td>
              <td style="color: #aaa; padding-bottom: 10px;">
                <strong style="color: #fff;">Review Your Assets</strong> - The tables above show all monitored IP addresses and hostnames from your ping data.
              </td>
            </tr>
            <tr>
              <td style="vertical-align: top; color: #5cc05c; font-size: 18px;">2.</td>
              <td style="color: #aaa; padding-bottom: 10px;">
                <strong style="color: #fff;">Search for an Asset</strong> - Copy an IP or hostname and paste it into the Quick Asset Search to find where it appears in other Splunk data.
              </td>
            </tr>
            <tr>
              <td style="vertical-align: top; color: #5cc05c; font-size: 18px;">3.</td>
              <td style="color: #aaa; padding-bottom: 10px;">
                <strong style="color: #fff;">Correlate Data</strong> - Use the results to understand which indexes contain data about your monitored assets. This helps you build correlation searches.
              </td>
            </tr>
            <tr>
              <td style="vertical-align: top; color: #5cc05c; font-size: 18px;">4.</td>
              <td style="color: #aaa;">
                <strong style="color: #fff;">Enrich with Lookup</strong> - Use <code style="background: #2a2a2a; padding: 2px 6px; border-radius: 3px;">| lookup ping_health_lookup.csv hostname</code> in any search to add ping health data.
              </td>
            </tr>
          </table>
        </div>
      </html>
    </panel>
  </row>

</dashboard>
